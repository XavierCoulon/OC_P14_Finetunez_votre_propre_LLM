# Copier ce fichier en .env et renseigner les valeurs
# Token HuggingFace avec droits write : https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repo cible (namespace/nom)
HF_DATASET_REPO=XavierCoulon/oc-p14-dataset

# true = privé, false = public
HF_PRIVATE=true
